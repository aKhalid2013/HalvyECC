{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Observation",
  "description": "Manual observation about the AI dev system",
  "type": "object",
  "required": ["date", "category", "title", "description", "severity"],
  "properties": {
    "date": {
      "type": "string",
      "format": "date"
    },
    "category": {
      "type": "string",
      "enum": [
        "process",
        "tooling",
        "agent_behavior",
        "documentation",
        "workflow",
        "cross_platform"
      ]
    },
    "title": {
      "type": "string",
      "maxLength": 120
    },
    "description": { "type": "string" },
    "severity": {
      "type": "string",
      "enum": ["low", "medium", "high", "critical"]
    },
    "proposed_fix": { "type": "string" },
    "related_specs": {
      "type": "array",
      "items": { "type": "string" }
    },
    "affected_platforms": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": ["claude_code", "antigravity", "codex", "gemini_cli", "claude_ai"]
      }
    }
  }
}
